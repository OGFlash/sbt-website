# Backend environment — copy to .env and fill in values
# Never commit .env to source control

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173

# AWS region for SES
AWS_REGION=us-east-1

# AWS credentials (for local dev; in Lambda use IAM role — leave blank)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# SES verified email identities
SES_SENDER_EMAIL=info@yourdomain.com
SES_RECIPIENT_EMAIL=caleb.yoder@yourdomain.com
